<NotepadPlus>
    <UserLang name="Wrench Acc32" ext="s asm" udlVersion="2.1">
        <Settings>
            <Global caseIgnored="no" allowFoldOfComments="yes" foldCompact="no" forcePureLC="0" decimalSeparator="0" />
            <Prefix Keywords1="no" Keywords2="no" Keywords3="no" Keywords4="yes" Keywords5="no" />
        </Settings>
        <KeywordLists>
            <!-- Директивы ассемблера -->
            <Keywords name="Delimiters">'00'</Keywords>
            <Keywords name="Folder+"></Keywords>
            <Keywords name="Folder-"></Keywords>
            <Keywords name="Operators">- + * / = &lt; &gt; , [ ] ( )</Keywords>
            <Keywords name="Comment">1;</Keywords>
            <Keywords name="Words1">.data .text .org .word .byte .END</Keywords>
            <!-- Инструкции acc32 -->
            <Keywords name="Words2">load store add sub and or xor jmp jz jnz jc halt nop push pop call ret</Keywords>
            <Keywords name="Words3">load_addr load_ind store_ind add_ind sub_ind cmp</Keywords>
            <!-- Регистры и специальные слова -->
            <Keywords name="Words4">acc r0 r1 r2 r3 r4 r5 r6 r7 sp pc</Keywords>
            <!-- Числа и константы -->
            <Keywords name="Words5">0x[0-9A-Fa-f]+ [0-9]+</Keywords>
        </KeywordLists>
        <Styles>
            <WordsStyle name="DEFAULT" styleID="11" fgColor="000000" bgColor="FFFFFF" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="COMMENTS" styleID="17" fgColor="008000" bgColor="FFFFFF" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="LINE COMMENTS" styleID="18" fgColor="008000" bgColor="FFFFFF" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="NUMBERS" styleID="20" fgColor="FF8000" bgColor="FFFFFF" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS1" styleID="21" fgColor="0000FF" bgColor="FFFFFF" fontName="" fontStyle="1" nesting="0" />
            <WordsStyle name="KEYWORDS2" styleID="22" fgColor="800080" bgColor="FFFFFF" fontName="" fontStyle="1" nesting="0" />
            <WordsStyle name="KEYWORDS3" styleID="23" fgColor="FF00FF" bgColor="FFFFFF" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS4" styleID="24" fgColor="008080" bgColor="FFFFFF" fontName="" fontStyle="1" nesting="0" />
            <WordsStyle name="KEYWORDS5" styleID="25" fgColor="FF0000" bgColor="FFFFFF" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="OPERATORS" styleID="28" fgColor="404040" bgColor="FFFFFF" fontName="" fontStyle="1" nesting="0" />
        </Styles>
    </UserLang>
</NotepadPlus>